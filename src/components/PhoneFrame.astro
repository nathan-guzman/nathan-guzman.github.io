---
interface Props {
  variant: 'iframe' | 'video';
  src: string;
  title?: string;
  poster?: string;
  allow?: string;
}

const { variant, src, title = 'App preview', poster, allow = '' } = Astro.props;
---

<div class="phone-frame mx-auto">
  <div class="phone-bezel">
    <div class="phone-notch" aria-hidden="true"></div>
    <div class="phone-screen">
      {variant === 'iframe' ? (
        <iframe
          src={src}
          title={title}
          loading="lazy"
          allow={allow}
          sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      ) : (
        <video
          src={src}
          poster={poster}
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-label={title}
        ></video>
      )}
    </div>
  </div>
</div>

<style>
  .phone-frame {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 375 / 812;
    filter: drop-shadow(0 24px 32px rgba(31, 31, 29, 0.18));
  }
  @media (min-width: 1024px) {
    .phone-frame {
      max-width: 340px;
    }
  }
  .phone-bezel {
    position: relative;
    width: 100%;
    height: 100%;
    background: #1F1F1D;
    border-radius: 42px;
    padding: 10px;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }
  .phone-notch {
    position: absolute;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    width: 90px;
    height: 22px;
    background: #0a0a09;
    border-radius: 999px;
    z-index: 2;
  }
  .phone-screen {
    width: 100%;
    height: 100%;
    background: #FAF7F2;
    border-radius: 32px;
    overflow: hidden;
    position: relative;
  }
  .phone-screen iframe,
  .phone-screen video {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    object-fit: cover;
  }
</style>
