---
interface Props {
  src: string;
  title?: string;
  allow?: string;
}

const { src, title = 'Embedded map', allow = '' } = Astro.props;
---

<div class="wide-embed">
  <iframe
    src={src}
    title={title}
    loading="lazy"
    allow={allow}
    sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
</div>

<style>
  .wide-embed {
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(139, 133, 121, 0.3);
    background: #F5F1E8;
    box-shadow: 0 18px 28px rgba(31, 31, 29, 0.12);
  }
  .wide-embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
</style>
