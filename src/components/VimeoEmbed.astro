---
interface Props {
  vimeoId: string;
  title?: string;
}

const { vimeoId, title = 'Vimeo video' } = Astro.props;
const src = `https://player.vimeo.com/video/${vimeoId}?title=0&byline=0&portrait=0`;
---

<div class="vimeo-wrap">
  <iframe
    src={src}
    title={title}
    loading="lazy"
    allow="autoplay; fullscreen; picture-in-picture"
    allowfullscreen
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
</div>

<style>
  .vimeo-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    background: #1F1F1D;
    box-shadow: 0 18px 28px rgba(31, 31, 29, 0.18);
  }
  .vimeo-wrap iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
</style>
